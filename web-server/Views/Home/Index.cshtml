@model DashboardViewModel
@{
    ViewData["Title"] = "Home Page";
}

@if (User.Identity!.IsAuthenticated)
{
    <div class="flex items-center flex-col gap-3">
        <partial name="_ServerInfo" model="@Model"/>
        <partial name="_SystemChart" model="@Model"/>
        <div class="mx-0 w-full max-w-4xl max-h-96 bg-main-900 rounded-xl border border-main-800 p-4">
            <h2></h2>
            <div class="overflow-scroll h-full" id="logs"></div>

        </div>
        <div class="mx-auto w-full max-w-4xl bg-main-900 rounded-xl border border-main-800 p-4">
            <form class="flex" hx-post="/Home/Command" hx-target="#logs" hx-swap="beforeend" hx-on::after-request="this.reset()"> 
                <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                <input class="w-full border-none outline-0" name="command" type="text" placeholder="Enter command"/>
                <button class="cursor-pointer" type="submit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg></button>
            </form>
        </div>
        
        <div class="mx-auto w-full max-w-4xl bg-main-900 rounded-xl border items-center border-main-800 p-4 space-y-3">
            <div class="flex justify-between">
                <p class="font-bold text-lg">Edit Server</p>
                <button class="flex bg-blue-600 rounded-lg p-2 px-4 cursor-pointer hover:bg-blue-500" type="submit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                    </svg>
                    Edit
                </button>

            </div>
            <div class="flex justify-between items-center">
                <div>
                    <p class="font-bold text-lg">Delete Server</p>
                    <p>Once you delete a server, there is no going back please be certain.</p>
                </div>
                <form asp-action="Delete" >
                    <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                    <button class="flex bg-red-600 rounded-lg p-2 px-4 cursor-pointer hover:bg-red-500" type="submit">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                            <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd"/>
                        </svg>
                        Delete
                    </button>
                </form>

            </div>
        </div>
        
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/logsHub")
        .build();

    connection.on("ReceiveLog", line => {
        const logs = document.getElementById("logs");
        logs.innerText += line + "\n";
        logs.scrollTop = logs.scrollHeight;
    });

    connection.start().then(() => {
        connection.invoke("StreamLogs", "@Model.ActiveServer.ServerName");
    });
</script>

    </div>

}


