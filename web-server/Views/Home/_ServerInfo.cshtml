@model ServerViewModel
<div class="bg-main-900 w-full max-w-4xl flex m-2 mx-0 p-2 rounded-xl border border-main-800 ">
    <div class="flex justify-between w-full flex-col md:flex-row space-y-1">
        <div class="flex">
            <img class="size-30 object-contain shrink-0" src="@Model.GetServerImagePath(@Model.ActiveServer.ServerType)">
            <div class="space-x-1 space-y-3">
                <select class=" bg-main-700 p-2 rounded-xl h-fit font-bold " name="serverId"
                        asp-items="@Model.GetServerSelectList()"
                        onchange="window.location.href='/Home/Index?serverId=' + this.value">
                </select>
                <div class="flex items-center space-x-1">
                    <div class="rounded-[1000px] size-[10px] @(Model.ActiveServerStatus.StartsWith("Running")
                                                                 ? "bg-green-500"
                                                                 : Model.ActiveServerStatus.StartsWith("Paused")
                                                                     ? "bg-yellow-500"
                                                                     : "bg-red-500")">
                    </div>
                    <p class="@(Model.ActiveServerStatus.StartsWith("Running") ? "text-green-500" :
                              Model.ActiveServerStatus.StartsWith("Paused") ? "text-yellow-500" : "text-red-500")">
                        @Model.ActiveServerStatus</p>
                </div>
                <p class="text-main-200 text-md">Created @Model.ActiveServer.CreatedAt.ToString("dd.MM.yyyy")</p>
            </div>
        </div>
        
        
        <div class="flex items-center">
            <div class=" border border-main-800 rounded-lg h-fit p-2 px-4 ">
                <button id="copy" class="flex cursor-pointer gap-1" class="cursor-pointer" onclick="updateClipboard()"> 
                    <p id="serverUrl">@Model.ServerUrl</p>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
                    </svg>
                </button>
            </div>
            
        </div>
        <div class="flex gap-2 items-center">
            @if (Model.ActiveServerStatus.StartsWith("Running"))
            {

                <form asp-controller="Home" asp-action="Restart" method="post" onsubmit="handleFormSubmit(this)">
                    <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                    <button
                        class="bg-main-900 hover:bg-main-800 border border-main-800 h-fit p-2 px-4 rounded-xl flex space-x-1 cursor-pointer">
                        
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-6 btn-spinner hidden animate-spin"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                             stroke="currentColor" class="size-6 btn-icon">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                        </svg>
                        <span class="btn-label">Restart</span>
                    </button>
                </form>
                <form asp-controller="Home" asp-action="Stop" method="post" onsubmit="handleFormSubmit(this)">
                    <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                    <button type="submit"
                            class="bg-red-600 hover:bg-red-500 border border-main-800 h-fit p-2 px-4 rounded-xl flex space-x-1 cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-6 btn-spinner hidden animate-spin"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="btn-icon size-6">
                            <path fill-rule="evenodd"
                                  d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z"
                                  clip-rule="evenodd"/>
                        </svg>
                        <span class="btn-label">Stop</span>
                    </button>
                </form>
            }
            else
            {

                <form asp-controller="Home" asp-action="Start" method="post" onsubmit="handleFormSubmit(this)">
                    <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                    <button
                        class="bg-green-600 hover:bg-green-500 border border-main-800 h-fit p-2 px-4 rounded-xl flex space-x-1 cursor-pointer">
                        
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-6 btn-spinner hidden animate-spin"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                        </svg>

                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="btn-icon size-6">
                            <path fill-rule="evenodd"
                                  d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z"
                                  clip-rule="evenodd"/>
                        </svg>
                        
                        <span class="btn-label">Start</span>
                    </button>
                </form>

            }
        </div>
    </div>
</div>
<script>

    function updateClipboard() {
        const serverUrl = document.getElementById('serverUrl');
        const copyButton = document.getElementById('copy');
        copyButton.setAttribute('disabled', '');
        const actualUrl = serverUrl.innerHTML;
        navigator.clipboard.writeText(serverUrl.innerHTML).then(
            () => {
                serverUrl.innerHTML = "Copied";
                setTimeout(() => {
                    serverUrl.innerHTML = actualUrl;
                    copyButton.removeAttribute('disabled');
                }, 1500)
                /* clipboard successfully set */
            },
            () => {
                /* clipboard write failed */
            },
        );
    }
    
</script>

    
