@model ServerViewModel
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-main-900 border border-main-800 rounded-xl p-6 w-full max-w-md mx-4">
        
        <!-- Title -->
        <h2 class="text-lg font-bold text-white">Delete Server</h2>
        
        <!-- Message -->
        <p class="text-main-200 mt-2">
            Are you sure you want to delete this server? This action cannot be undone.
        </p>

        <!-- Actions -->
        <div class="flex justify-end gap-2 mt-6">
            
            <!-- Cancel -->
            <button type="button"
                    onclick="closeModal()"
                    class="px-4 py-2 rounded-lg bg-main-800 hover:bg-main-700 border border-main-700">
                Cancel
            </button>

            <!-- Confirm delete -->
            <form method="post" action="/Home/Delete">
                <input type="hidden" name="serverName" value="@Model.ActiveServer.ServerName"/>
                
                <button type="submit"
                        class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500 text-white">
                    Delete
                </button>
            </form>

        </div>
    </div>
</div>