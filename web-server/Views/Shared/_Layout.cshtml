<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - web_server</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="bg-main-950 flex">
    <header class="lg:sticky lg:top-0 lg:min-h-screen lg:w-fit w-0 bg-main-950">
        <nav id="navigation" class="hidden data-active:flex lg:flex fixed lg:sticky top-0 left-0  w-64 lg:w-fit h-screen flex-col space-y-1 border rounded-xl border-main-800 z-50">

            <div class="flex flex-col justify-between h-full">

                <div class="w-fit">

                    <a class="w-[75px]" asp-action="Index" asp-controller="Home">
                        <img src="/images/NodeSentinel.png" alt="Node Sentinel logo" class="w-[75px]" />
                    </a>
                        
                    <a class="flex text-center font-bold w-full justify-center p-2" asp-action="Index" asp-controller="Home">
                        <p class="text-xl">Node</p>
                        <p class="text-xl text-brand">Sentinel</p>
                    </a>
                        @if(User.Identity!.IsAuthenticated) {
                            <a class="flex p-1 m-1 space-x-1">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8.25V18a2.25 2.25 0 0 0 2.25 2.25h13.5A2.25 2.25 0 0 0 21 18V8.25m-18 0V6a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 6v2.25m-18 0h18M5.25 6h.008v.008H5.25V6ZM7.5 6h.008v.008H7.5V6Zm2.25 0h.008v.008H9.75V6Z" />
                                </svg>
                                <p>Dashboard</p>
                            </a>

                            <a class="flex p-1 mx-1 space-x-1">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>
                                <p>New Server</p>
                            </a>

                            <a class="flex p-1 mx-1 space-x-1">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
                                </svg>
                                <p>Servers</p>
                            </a>

                            <a class="flex p-1 mx-1 space-x-1">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                                </svg>
                                <p>Backups</p>
                            </a>

                            <a class="flex p-1 mx-1 space-x-1">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                                </svg>
                                <p>Logs</p>
                            </a>
                        }

                </div>
                <div class="bg-main-900 m-2 rounded-xl border border-main-800 flex space-x-5 p-3 h-[100px] justify-center items-center">
                        @if(User.Identity!.IsAuthenticated) {
                            <div class="flex flex-col h-full justify-between items-center">
                                <p>@User.Identity.Name</p>

                                <form asp-controller="Auth" asp-action="logout" method="post">
                                    <button type="submit" class=" rounded-lg bg-main-800 hover:bg-main-700 p-2 flex">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15M12 9l3 3m0 0-3 3m3-3H2.25" />
                                        </svg>
                                        Logout
                                    </button>
                                </form>
                            </div>
                        }
                        else {
                            <a class="bg-main-800 rounded-xl text-center h-fit " asp-action="account" asp-controller="Auth">
                                <p class="p-1 px-2">Sign in</p>
                            </a>
                            <a class="bg-main-200 rounded-xl text-center h-fit " asp-action="account" asp-controller="Auth" asp-route-tab="register">
                                <p class="text-black p-1 px-2 ">Sign up</p>
                            </a>
                        }
                </div>
            </div>
        </nav>
    </header>
    <div class="flex flex-col flex-1">
        <svg id="menu" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-white sticky top-0 bg-dark-900 text-left data-active:hidden size-15 lg:hidden" onclick="toggleNav()">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
