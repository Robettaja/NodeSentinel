
        
        <h2 class="font-bold text-xl text-center " >Login to your account</h2>

        <form asp-controller="Auth" asp-action="Login" method="post" class="w-full lg:max-w-1/2">

            <div class="flex flex-col space-y-3 w-4xs md:w-full p-2" >
                <label class="font-medium text-lg ">Username</label>
                <input type="text" name="username"  required class="rounded-lg p-3 w-full border-none bg-dark-800"/>
                <label class="font-medium text-lg ">Password</label>
                <input type="password" name="password"  required class="rounded-lg p-3 w-full border-none  bg-dark-800"/>

                @if(TempData["errors"]!= null) {
                    <p class="text-red-500">@TempData["errors"]</p>

                }
                <button type="submit" class="w-42.5 rounded-xl bg-blue-600 hover:bg-blue-500 mt-4 p-2 text-lg cursor-pointer">Login</button>
                <div class="flex space-x-3 mt-2">
                    <p class="text-text-secondary font-light">Don't have an account?</p>
                    <a asp-action="account" asp-controller="Auth" asp-route-tab="register" class="text-blue-700 hover:text-blue-600 underline">Create Account</a>
                </div>
            </div>
        </form>

